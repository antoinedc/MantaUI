{
  "expo": {
    "name": "Manta",
    "slug": "bui",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "manta",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.antoinedc.bui",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Manta uses the camera to scan the pairing QR code shown by the desktop app."
      }
    },
    "android": {
      "package": "com.antoinedc.bui",
      "permissions": ["CAMERA"]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Manta uses the camera to scan the pairing QR code shown by the desktop app."
        }
      ],
      "expo-secure-store"
    ]
  }
}
