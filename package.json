{
  "name": "better-ui",
  "version": "0.0.1",
  "description": "Desktop client for remote Claude Code sessions",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "rebuild": "electron-rebuild -f -w node-pty",
    "rename:dev": "bash scripts/rename-dev-app.sh",
    "postinstall": "electron-rebuild -f -w node-pty || true; bash scripts/rename-dev-app.sh || true",
    "mobile": "node src/server/index.mjs",
    "pair": "node scripts/bui-pair.mjs",
    "pack": "node scripts/release/pack.mjs",
    "pack:desktop": "electron-vite build && electron-builder --config electron-builder.yml",
    "test": "vitest run && node --test src/server/*.test.mjs src/relay/*.test.mjs src/relay/agent/*.test.mjs scripts/*.test.mjs",
    "test:server": "node --test src/server/*.test.mjs src/relay/*.test.mjs src/relay/agent/*.test.mjs",
    "test:watch": "vitest",
    "build:mobile": "vite build --config electron.vite.config.mobile.ts"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "node-sqlite3-wasm": "^0.8.59",
    "prism-react-renderer": "^2.4.1",
    "qrcode": "^1.5.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "web-push": "^3.6.7",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@xterm/addon-clipboard": "^0.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "autoprefixer": "^10.4.19",
    "cmdk": "^1.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^25.1.0",
    "electron-updater": "^6.3.0",
    "electron-vite": "^2.3.0",
    "eslint": "^10.6.0",
    "jscpd": "^4.2.3",
    "jsdom": "^25.0.1",
    "knip": "^6.14.1",
    "postcss": "^8.4.39",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^4.1.6",
    "zustand": "^4.5.0"
  }
}
